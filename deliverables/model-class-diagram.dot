digraph InvoicingSystem {
    rankdir=LR;
    graph [fontsize=10 fontname="Arial" pad="0.2"];
    node [shape=record fontname="Arial" fontsize=10 margin="0.15,0.08"];
    edge [fontname="Arial" fontsize=9];

    Customer [label="{Customer|name\ltaxId\laddress\l}"];
    Product [label="{Product|name\lsku\lunitPrice\l}"];
    InvoiceItem [label="{InvoiceItem|productName\lsku\lquantity\lunitPrice\lsubtotal\l}"];
    CurrentInvoiceModel [label="{CurrentInvoiceModel|selectedCustomer\lcustomerTaxId\lcustomerAddress\linvoiceNumber\lissueDate\ldueDate\litems\lsubtotal\ltax\ltotal\l}"];
    Invoice [label="{Invoice|invoiceNumber\lcustomerName\lcustomerTaxId\lcustomerAddress\lissueDate\ldueDate\lstatus\lsubtotal\ltax\ltotal\litems\l}"];
    CatalogService [label="{CatalogService|customers\lproducts\l}"];
    InvoiceService [label="{InvoiceService|invoiceNumberGenerator\linvoiceRepository\l}"];
    InvoiceRepository [label="{InvoiceRepository|invoices\l}"];
    InvoiceNumberGenerator [label="{InvoiceNumberGenerator|counter\l}"];
    InvoiceController [label="{InvoiceController|invoiceModel\lcatalogService\linvoiceService\l}"];
    HistoryController [label="{HistoryController|filteredInvoices\l}"];

    CurrentInvoiceModel -> Customer [label="selected"];
    CurrentInvoiceModel -> InvoiceItem [label="contains *"];
    Invoice -> InvoiceItem [label="contains *"];
    CatalogService -> Customer [label="stores *"];
    CatalogService -> Product [label="stores *"];
    InvoiceService -> InvoiceNumberGenerator [label="uses"];
    InvoiceService -> InvoiceRepository [label="uses"];
    InvoiceService -> Invoice [label="builds"];
    InvoiceRepository -> Invoice [label="stores *"];
    InvoiceController -> CurrentInvoiceModel [label="binds"];
    InvoiceController -> CatalogService [label="uses"];
    InvoiceController -> InvoiceService [label="uses"];
    HistoryController -> InvoiceRepository [label="reads"];
}
